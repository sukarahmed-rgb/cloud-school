{
  "name": "cloud-school",
  "version": "1.0.0",
  "description": "منصة تعليمية سحابية للطلاب المكفوفين",
  "main": "cloud_school_app.js",
  "scripts": {
    "test": "jest",
    "test:ui": "playwright test",
    "dev": "vite",
    "start": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "lint": "eslint . --ext .js --ignore-pattern dist --ignore-pattern node_modules",
    "lint:fix": "eslint . --ext .js --ignore-pattern dist --ignore-pattern node_modules --fix",
    "format": "prettier --write \"**/*.js\" \"!dist/**\" \"!node_modules/**\"",
    "format:check": "prettier --check \"**/*.js\" \"!dist/**\" \"!node_modules/**\"",
    "prepare": "husky",
    "deploy:hosting": "npx firebase deploy --only hosting",
    "deploy": "npx firebase deploy"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.35.0",
    "babel-jest": "^30.4.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "firebase-tools": "^15.23.0",
    "husky": "^9.1.7",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "lint-staged": "^17.0.8",
    "live-server": "^1.2.2",
    "playwright": "^1.35.0",
    "prettier": "^3.9.5",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  }
}
