# ===== Cloud School Environment Variables =====
# انسخ هذا الملف إلى .env وعدّل القيم

# مفتاح Google Gemini API (مطلوب لتشغيل الذكاء الاصطناعي)
# اتركه فارغاً — المستخدم يستطيع إدخاله من واجهة التطبيق
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# مفتاح Firebase Web API — ضروري لتأكيد Firebase ID tokens على السيرفر
# احصل عليه من: Firebase Console > Project Settings > Web Apps > SDK config
FIREBASE_API_KEY=your_firebase_web_api_key

# منفذ الخادم (اختياري، افتراضي 8081)
PORT=8081
