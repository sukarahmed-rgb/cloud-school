# ===== Cloud School Environment Variables =====
# انسخ هذا الملف إلى .env وعدّل القيم

# مفتاح Google Gemini API (مطلوب لتشغيل الذكاء الاصطناعي)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# منفذ الخادم الوسيط (Proxy Server)
PORT=3001

# عنوان CORS المسموح (أصل الطلب من الواجهة الأمامية)
CORS_ORIGIN=http://127.0.0.1:8080

# ===== Firebase Configuration (اختياري) =====
# إذا كنت تستخدم Firebase للمزامنة السحابية، قم بتعريف المتغيرات أدناه
# وقم بتضمينها في index.html كـ __firebase_config
# FIREBASE_API_KEY=
# FIREBASE_PROJECT_ID=
# FIREBASE_APP_ID=
