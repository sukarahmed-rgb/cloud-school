rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // القاعدة العامة: رفض الوصول ما لم يُسمح به صراحة
    match /{document=**} {
      allow read, write: if false;
    }

    // مسار بيانات التطبيق
    match /artifacts/{appId}/public/data/{collection} {

      // السماح بالقراءة للمستخدمين الموثقين
      allow read: if request.auth != null;

      // السماح بالكتابة للمستخدمين الموثقين
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // منع التعديل أو الحذف للبيانات المرفوعة
      allow update, delete: if false;
    }

    // حماية خاصة للـ API key (إذا خُزنت)
    match /artifacts/{appId}/private/{document=**} {
      allow read, write: if request.auth != null
                        && request.auth.uid == resource.data.userId;
    }
  }
}
